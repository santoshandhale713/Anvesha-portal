<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Anvesha – Certificate Download</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --navy:    #0C1D3A;
      --navy2:   #162d54;
      --gold:    #B8862A;
      --gold-lt: #F4E4B8;
      --gold-md: #D4A84B;
      --cream:   #FDFAF4;
      --white:   #FFFFFF;
      --muted:   #6B7280;
      --border:  #E5DECE;
      --danger:  #B91C1C;
      --success: #166534;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--navy); min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; }

    @keyframes fadeSlideUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes shimmer { 0% { background-position: -400px 0; } 100% { background-position: 400px 0; } }
    @keyframes popIn { 0% { opacity: 0; transform: scale(0.92) translateY(10px); } 60% { transform: scale(1.02) translateY(-2px); } 100% { opacity: 1; transform: scale(1) translateY(0); } }
    @keyframes spin { to { transform: rotate(360deg); } }

    .anim-fade-up   { animation: fadeSlideUp 0.55s cubic-bezier(.22,.68,0,1.2) both; }
    .anim-fade-up-2 { animation: fadeSlideUp 0.55s 0.1s cubic-bezier(.22,.68,0,1.2) both; }
    .anim-fade-up-3 { animation: fadeSlideUp 0.55s 0.2s cubic-bezier(.22,.68,0,1.2) both; }
    .anim-pop       { animation: popIn 0.45s cubic-bezier(.22,.68,0,1.2) both; }

    header { background: var(--navy); padding: 20px 24px 18px; border-bottom: 3px solid var(--gold); animation: fadeIn 0.5s ease both; }
    .header-inner { max-width: 700px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
    .logo-group { display: flex; align-items: center; gap: 12px; }
    .logo-img { height: 52px; width: auto; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.9; }
    .logo-divider { width: 1px; height: 40px; background: #2A3F5F; }
    .brand-block { text-align: center; flex: 1; }
    .brand-name { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 600; letter-spacing: 3px; display: block; background: linear-gradient(90deg, #F4E4B8 0%, #D4A84B 40%, #F4E4B8 60%, #D4A84B 100%); background-size: 400px 100%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: shimmer 3s linear infinite; }
    .brand-sub { font-size: 11px; color: #94A3B8; letter-spacing: 3px; text-transform: uppercase; margin-top: 3px; display: block; }
    .brand-tag { font-size: 10px; color: #64748B; letter-spacing: 1px; margin-top: 4px; display: block; }

    main { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 44px 16px 64px; }
    .card { background: var(--white); border-radius: 18px; border: 1px solid var(--border); padding: 38px 36px; width: 100%; max-width: 500px; box-shadow: 0 8px 40px rgba(12,29,58,0.09); }
    .card-title { font-family: 'Playfair Display', serif; font-size: 23px; font-weight: 500; color: var(--navy); margin-bottom: 7px; }
    .card-desc { font-size: 14px; color: var(--muted); line-height: 1.65; margin-bottom: 28px; }
    label { display: block; font-size: 13px; font-weight: 500; color: var(--navy); margin-bottom: 8px; letter-spacing: 0.4px; }
    .input-group { display: flex; gap: 10px; }
    input[type="tel"] { flex: 1; padding: 12px 16px; font-size: 16px; font-family: 'DM Sans', sans-serif; border: 1.5px solid var(--border); border-radius: 10px; outline: none; color: var(--navy); background: var(--cream); transition: border-color 0.2s, box-shadow 0.2s; letter-spacing: 1px; }
    input[type="tel"]:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,134,42,0.12); }
    input[type="tel"]::placeholder { color: #B0A890; letter-spacing: 0; }
    button#lookupBtn { padding: 12px 22px; background: var(--navy); color: var(--gold-lt); border: none; border-radius: 10px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; cursor: pointer; white-space: nowrap; transition: background 0.2s, transform 0.1s, box-shadow 0.2s; }
    button#lookupBtn:hover { background: var(--navy2); box-shadow: 0 4px 16px rgba(12,29,58,0.25); }
    button#lookupBtn:active { transform: scale(0.97); }
    button#lookupBtn:disabled { opacity: 0.7; cursor: not-allowed; }

    .spinner { display: inline-block; width: 15px; height: 15px; border: 2px solid rgba(244,228,184,0.4); border-top-color: var(--gold-lt); border-radius: 50%; animation: spin 0.7s linear infinite; vertical-align: middle; margin-right: 6px; }

    #result { margin-top: 24px; }

    .month-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
    .month-tab { padding: 7px 16px; border-radius: 20px; border: 1.5px solid var(--border); background: var(--cream); color: var(--muted); font-size: 13px; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: all 0.18s; }
    .month-tab:hover { border-color: var(--gold); color: var(--gold); }
    .month-tab.active { background: var(--navy); border-color: var(--navy); color: var(--gold-lt); font-weight: 500; }

    .result-success { background: #F0FDF4; border: 1px solid #BBF7D0; border-radius: 14px; padding: 22px 24px; }
    .result-success .greeting { font-family: 'Playfair Display', serif; font-size: 18px; color: var(--success); margin-bottom: 5px; }
    .result-success .meta { font-size: 13px; color: #4B7C63; margin-bottom: 18px; line-height: 1.6; }
    .download-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--gold); color: var(--white); text-decoration: none; padding: 11px 24px; border-radius: 9px; font-size: 14px; font-weight: 500; font-family: 'DM Sans', sans-serif; transition: background 0.18s, transform 0.1s, box-shadow 0.18s; }
    .download-btn:hover { background: #96691E; box-shadow: 0 4px 14px rgba(184,134,42,0.35); }
    .download-btn:active { transform: scale(0.97); }

    .result-error { background: #FEF2F2; border: 1px solid #FECACA; border-radius: 14px; padding: 18px 22px; font-size: 14px; color: var(--danger); line-height: 1.65; }

    .divider { border: none; border-top: 1px dashed var(--border); margin: 28px 0; }
    .help-text { font-size: 12.5px; color: var(--muted); line-height: 1.65; text-align: center; }
    footer { text-align: center; padding: 16px; font-size: 12px; color: #9CA3AF; border-top: 1px solid var(--border); }

    @media (max-width: 480px) {
      header { padding: 16px; }
      .header-inner { flex-direction: column; gap: 10px; }
      .logo-group { justify-content: center; }
      .logo-divider { display: none; }
      .brand-name { font-size: 26px; }
      .card { padding: 26px 18px; }
      .input-group { flex-direction: column; }
      button#lookupBtn { width: 100%; padding: 13px; }
    }
  </style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="logo-group">
      <img class="logo-img" src="https://resource.cdn.icai.org/icai-logo.png"
        onerror="this.style.display='none'; this.onerror=null;" alt="ICAI" />
      <div class="logo-divider"></div>
      <img class="logo-img" src="https://wirc-icai.org/images/logo.png"
        onerror="this.style.display='none'; document.getElementById('wicasa-fb').style.display='block'; this.onerror=null;" alt="WICASA" />
      <div id="wicasa-fb" style="display:none; line-height:1.2;">
        <span style="font-family:'Playfair Display',serif; font-size:15px; font-weight:600; color:#F4E4B8; letter-spacing:1px;">WICASA</span><br/>
        <span style="font-size:9px; color:#64748B; letter-spacing:1.5px;">WIRC · ICAI</span>
      </div>
    </div>
    <div class="brand-block">
      <span class="brand-name">ANVESHA</span>
      <span class="brand-sub">Monthly Newsletter</span>
      <span class="brand-tag">Chhatrapati Sambhajinagar Branch</span>
    </div>
    <div style="width:110px; display:flex; justify-content:flex-end;">
      <span style="font-size:10px; color:#334155; letter-spacing:1px; text-align:right; line-height:1.6;">WESTERN INDIA<br/>REGIONAL COUNCIL<br/>OF ICAI</span>
    </div>
  </div>
</header>

<main>
  <div class="card anim-fade-up">
    <h1 class="card-title anim-fade-up">Download Your Certificate</h1>
    <p class="card-desc anim-fade-up-2">Enter the mobile number you submitted in the contribution form. Your participation certificate will appear below.</p>
    <div class="anim-fade-up-3">
      <label for="mobileInput">Mobile Number</label>
      <div class="input-group">
        <input type="tel" id="mobileInput" placeholder="Enter 10-digit number" maxlength="10" inputmode="numeric" autocomplete="off" />
        <button id="lookupBtn">Find Certificate</button>
      </div>
    </div>
    <div id="result"></div>
    <hr class="divider" />
    <p class="help-text">Having trouble? Contact your branch WICASA representative<br />or email the newsletter committee.</p>
  </div>
</main>

<footer>&copy; 2025 WICASA &ndash; Chhatrapati Sambhajinagar Branch &middot; Anvesha Newsletter</footer>

<script>
  // ════════════════════════════════════════════════════════
  //  PASTE YOUR GOOGLE APPS SCRIPT WEB APP URL BELOW
  // ════════════════════════════════════════════════════════
  var SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwJSmF-EpBu1GynKGpZqenluegxHbNxfrBZVfyDVePzF-Xm4DhCERrJqxPIe6wS14GBKA/exec";
  // Example: "https://script.google.com/macros/s/AKfycb.../exec"

  var currentMobile = "";
  var currentEntries = [];

  function renderCard(selectedMonth) {
    var entry = currentEntries.find(function(e) { return e.month === selectedMonth; });

    var tabsHtml = "";
    if (currentEntries.length > 1) {
      tabsHtml = '<div class="month-tabs">';
      currentEntries.forEach(function(e) {
        var cls = e.month === selectedMonth ? "month-tab active" : "month-tab";
        tabsHtml += '<button class="' + cls + '" data-month="' + e.month + '">' + e.month + '</button>';
      });
      tabsHtml += '</div>';
    }

    var resultDiv = document.getElementById("result");
    resultDiv.innerHTML = '<div class="result-success anim-pop">'
      + tabsHtml
      + '<div class="greeting">Congratulations, ' + entry.name + '!</div>'
      + '<div class="meta">Contribution: <strong>' + entry.category + '</strong> &nbsp;&bull;&nbsp; Issue: <strong>' + entry.month + '</strong></div>'
      + '<a class="download-btn" href="' + entry.file + '" download="' + entry.name + ' - Anvesha ' + entry.month + '.pdf">'
      + '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>'
      + 'Download Certificate (PDF)</a>'
      + '</div>';

    // Attach tab events
    resultDiv.querySelectorAll(".month-tab").forEach(function(tab) {
      tab.addEventListener("click", function() {
        renderCard(this.getAttribute("data-month"));
      });
    });
  }

  function lookupCertificate() {
    var input = document.getElementById("mobileInput").value.trim();
    var resultDiv = document.getElementById("result");
    var btn = document.getElementById("lookupBtn");

    if (input.length !== 10 || isNaN(input)) {
      resultDiv.innerHTML = '<div class="result-error anim-pop">Please enter a valid 10-digit mobile number.</div>';
      return;
    }

    // Show loading state
    btn.innerHTML = '<span class="spinner"></span> Searching...';
    btn.disabled = true;
    resultDiv.innerHTML = "";

    // Call the Apps Script backend
    fetch(SCRIPT_URL + "?mobile=" + input)
      .then(function(res) { return res.json(); })
      .then(function(data) {
        btn.innerHTML = "Find Certificate";
        btn.disabled = false;

        if (data.status === "found") {
          currentMobile = input;
          currentEntries = data.entries;
          renderCard(currentEntries[0].month);
        } else {
          resultDiv.innerHTML = '<div class="result-error anim-pop">'
            + 'No certificate found for this number. Please ensure you have entered '
            + 'the mobile number used during form submission.'
            + '</div>';
        }
      })
      .catch(function() {
        btn.innerHTML = "Find Certificate";
        btn.disabled = false;
        resultDiv.innerHTML = '<div class="result-error anim-pop">'
          + 'Something went wrong. Please check your internet connection and try again.'
          + '</div>';
      });
  }

  document.getElementById("lookupBtn").addEventListener("click", lookupCertificate);
  document.getElementById("mobileInput").addEventListener("keydown", function(e) {
    if (e.key === "Enter") lookupCertificate();
  });
  document.getElementById("mobileInput").addEventListener("input", function() {
    this.value = this.value.replace(/\D/g, "");
  });
</script>

</body>
</html>
